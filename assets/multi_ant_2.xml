<!-- Multi-Ant Scene: 2 robots + cooperative push box
     Each robot is an Ant-style quadruped (8 DoF, 4 legs).
     Bodies/joints/geoms/actuators suffixed _r0, _r1.
     Robot 0 spawns at y=0, Robot 1 at y=2.5.
     Touch sensors at each foot (4 per robot = 8 total).
     Push box is a free body used for task 3 (coop_push). -->
<mujoco model="multi_ant_2">
  <compiler angle="degree" inertiafromgeom="true" autolimits="true"/>
  <option integrator="RK4" timestep="0.01"/>

  <default>
    <joint armature="1" damping="1" limited="true"/>
    <geom conaffinity="0" condim="3" density="5.0"
          friction="1.0 0.5 0.5" margin="0.01" rgba="0.8 0.6 0.4 1"/>
  </default>

  <asset>
    <texture name="texplane" type="2d" builtin="checker"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" width="512" height="512"/>
    <material name="MatPlane" reflectance="0.5" texture="texplane"
              texrepeat="1 1" texuniform="true"/>
    <material name="robot0_mat" rgba="0.8 0.3 0.3 1"/>
    <material name="robot1_mat" rgba="0.3 0.3 0.8 1"/>
    <material name="box_mat"    rgba="0.9 0.9 0.2 1"/>
  </asset>

  <worldbody>
    <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true"
           exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
    <geom conaffinity="1" condim="3" material="MatPlane" name="floor"
          pos="0 0 0" size="50 50 0.1" type="plane"/>

    <!-- ==================== ROBOT 0 (red, y=0) ==================== -->
    <body name="torso_r0" pos="0 0 0.75">
      <joint name="root_r0" type="free"/>
      <geom name="torso_geom_r0" type="sphere" size="0.25" material="robot0_mat"/>

      <!-- Front-left leg -->
      <body name="front_left_leg_r0" pos="0 0 0">
        <geom name="aux_1_geom_r0" fromto="0 0 0 0.2 0.2 0" size="0.08" type="capsule"/>
        <body name="aux_1_r0" pos="0.2 0.2 0">
          <joint name="hip_1_r0" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="left_leg_geom_r0" fromto="0 0 0 0.2 0.2 0" size="0.08" type="capsule"/>
          <body name="left_ankle_r0" pos="0.2 0.2 0">
            <joint name="ankle_1_r0" axis="-1 1 0" range="30 70" type="hinge"/>
            <geom name="left_ankle_geom_r0" fromto="0 0 0 0.4 0.4 0" size="0.08" type="capsule"
                  rgba="0.9 0.4 0.4 1" conaffinity="1" condim="3"/>
            <site name="foot_fl_r0" pos="0.4 0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Front-right leg -->
      <body name="front_right_leg_r0" pos="0 0 0">
        <geom name="aux_2_geom_r0" fromto="0 0 0 0.2 -0.2 0" size="0.08" type="capsule"/>
        <body name="aux_2_r0" pos="0.2 -0.2 0">
          <joint name="hip_2_r0" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="right_leg_geom_r0" fromto="0 0 0 0.2 -0.2 0" size="0.08" type="capsule"/>
          <body name="right_ankle_r0" pos="0.2 -0.2 0">
            <joint name="ankle_2_r0" axis="1 1 0" range="30 70" type="hinge"/>
            <geom name="right_ankle_geom_r0" fromto="0 0 0 0.4 -0.4 0" size="0.08" type="capsule"
                  rgba="0.9 0.4 0.4 1" conaffinity="1" condim="3"/>
            <site name="foot_fr_r0" pos="0.4 -0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Back-left leg -->
      <body name="back_left_leg_r0" pos="0 0 0">
        <geom name="aux_3_geom_r0" fromto="0 0 0 -0.2 0.2 0" size="0.08" type="capsule"/>
        <body name="aux_3_r0" pos="-0.2 0.2 0">
          <joint name="hip_3_r0" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="back_leg_geom_r0" fromto="0 0 0 -0.2 0.2 0" size="0.08" type="capsule"/>
          <body name="back_left_ankle_r0" pos="-0.2 0.2 0">
            <joint name="ankle_3_r0" axis="1 1 0" range="30 70" type="hinge"/>
            <geom name="back_left_ankle_geom_r0" fromto="0 0 0 -0.4 0.4 0" size="0.08" type="capsule"
                  rgba="0.9 0.4 0.4 1" conaffinity="1" condim="3"/>
            <site name="foot_bl_r0" pos="-0.4 0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Back-right leg -->
      <body name="back_right_leg_r0" pos="0 0 0">
        <geom name="aux_4_geom_r0" fromto="0 0 0 -0.2 -0.2 0" size="0.08" type="capsule"/>
        <body name="aux_4_r0" pos="-0.2 -0.2 0">
          <joint name="hip_4_r0" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="back_right_leg_geom_r0" fromto="0 0 0 -0.2 -0.2 0" size="0.08" type="capsule"/>
          <body name="back_right_ankle_r0" pos="-0.2 -0.2 0">
            <joint name="ankle_4_r0" axis="-1 1 0" range="30 70" type="hinge"/>
            <geom name="back_right_ankle_geom_r0" fromto="0 0 0 -0.4 -0.4 0" size="0.08" type="capsule"
                  rgba="0.9 0.4 0.4 1" conaffinity="1" condim="3"/>
            <site name="foot_br_r0" pos="-0.4 -0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>
    </body>

    <!-- ==================== ROBOT 1 (blue, y=2.5) ==================== -->
    <body name="torso_r1" pos="0 2.5 0.75">
      <joint name="root_r1" type="free"/>
      <geom name="torso_geom_r1" type="sphere" size="0.25" material="robot1_mat"/>

      <!-- Front-left leg -->
      <body name="front_left_leg_r1" pos="0 0 0">
        <geom name="aux_1_geom_r1" fromto="0 0 0 0.2 0.2 0" size="0.08" type="capsule"/>
        <body name="aux_1_r1" pos="0.2 0.2 0">
          <joint name="hip_1_r1" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="left_leg_geom_r1" fromto="0 0 0 0.2 0.2 0" size="0.08" type="capsule"/>
          <body name="left_ankle_r1" pos="0.2 0.2 0">
            <joint name="ankle_1_r1" axis="-1 1 0" range="30 70" type="hinge"/>
            <geom name="left_ankle_geom_r1" fromto="0 0 0 0.4 0.4 0" size="0.08" type="capsule"
                  rgba="0.4 0.4 0.9 1" conaffinity="1" condim="3"/>
            <site name="foot_fl_r1" pos="0.4 0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Front-right leg -->
      <body name="front_right_leg_r1" pos="0 0 0">
        <geom name="aux_2_geom_r1" fromto="0 0 0 0.2 -0.2 0" size="0.08" type="capsule"/>
        <body name="aux_2_r1" pos="0.2 -0.2 0">
          <joint name="hip_2_r1" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="right_leg_geom_r1" fromto="0 0 0 0.2 -0.2 0" size="0.08" type="capsule"/>
          <body name="right_ankle_r1" pos="0.2 -0.2 0">
            <joint name="ankle_2_r1" axis="1 1 0" range="30 70" type="hinge"/>
            <geom name="right_ankle_geom_r1" fromto="0 0 0 0.4 -0.4 0" size="0.08" type="capsule"
                  rgba="0.4 0.4 0.9 1" conaffinity="1" condim="3"/>
            <site name="foot_fr_r1" pos="0.4 -0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Back-left leg -->
      <body name="back_left_leg_r1" pos="0 0 0">
        <geom name="aux_3_geom_r1" fromto="0 0 0 -0.2 0.2 0" size="0.08" type="capsule"/>
        <body name="aux_3_r1" pos="-0.2 0.2 0">
          <joint name="hip_3_r1" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="back_leg_geom_r1" fromto="0 0 0 -0.2 0.2 0" size="0.08" type="capsule"/>
          <body name="back_left_ankle_r1" pos="-0.2 0.2 0">
            <joint name="ankle_3_r1" axis="1 1 0" range="30 70" type="hinge"/>
            <geom name="back_left_ankle_geom_r1" fromto="0 0 0 -0.4 0.4 0" size="0.08" type="capsule"
                  rgba="0.4 0.4 0.9 1" conaffinity="1" condim="3"/>
            <site name="foot_bl_r1" pos="-0.4 0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>

      <!-- Back-right leg -->
      <body name="back_right_leg_r1" pos="0 0 0">
        <geom name="aux_4_geom_r1" fromto="0 0 0 -0.2 -0.2 0" size="0.08" type="capsule"/>
        <body name="aux_4_r1" pos="-0.2 -0.2 0">
          <joint name="hip_4_r1" axis="0 0 1" range="-30 30" type="hinge"/>
          <geom name="back_right_leg_geom_r1" fromto="0 0 0 -0.2 -0.2 0" size="0.08" type="capsule"/>
          <body name="back_right_ankle_r1" pos="-0.2 -0.2 0">
            <joint name="ankle_4_r1" axis="-1 1 0" range="30 70" type="hinge"/>
            <geom name="back_right_ankle_geom_r1" fromto="0 0 0 -0.4 -0.4 0" size="0.08" type="capsule"
                  rgba="0.4 0.4 0.9 1" conaffinity="1" condim="3"/>
            <site name="foot_br_r1" pos="-0.4 -0.4 0" size="0.1" type="sphere"/>
          </body>
        </body>
      </body>
    </body>

    <!-- ==================== PUSH BOX (coop_push task) ==================== -->
    <body name="push_box" pos="3.0 1.25 0.15">
      <joint name="box_joint" type="free"/>
      <geom name="box_geom" type="box" size="0.3 0.3 0.15" mass="5.0"
            material="box_mat" conaffinity="1" condim="3" friction="1.0 0.5 0.5"/>
    </body>
  </worldbody>

  <actuator>
    <!-- Robot 0: 8 motors -->
    <motor name="m_hip_1_r0"   joint="hip_1_r0"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_1_r0" joint="ankle_1_r0" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_2_r0"   joint="hip_2_r0"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_2_r0" joint="ankle_2_r0" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_3_r0"   joint="hip_3_r0"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_3_r0" joint="ankle_3_r0" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_4_r0"   joint="hip_4_r0"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_4_r0" joint="ankle_4_r0" gear="150" ctrlrange="-1 1"/>
    <!-- Robot 1: 8 motors -->
    <motor name="m_hip_1_r1"   joint="hip_1_r1"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_1_r1" joint="ankle_1_r1" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_2_r1"   joint="hip_2_r1"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_2_r1" joint="ankle_2_r1" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_3_r1"   joint="hip_3_r1"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_3_r1" joint="ankle_3_r1" gear="150" ctrlrange="-1 1"/>
    <motor name="m_hip_4_r1"   joint="hip_4_r1"   gear="150" ctrlrange="-1 1"/>
    <motor name="m_ankle_4_r1" joint="ankle_4_r1" gear="150" ctrlrange="-1 1"/>
  </actuator>

  <sensor>
    <!-- Touch sensors at each foot (4 per robot) -->
    <touch name="touch_fl_r0" site="foot_fl_r0"/>
    <touch name="touch_fr_r0" site="foot_fr_r0"/>
    <touch name="touch_bl_r0" site="foot_bl_r0"/>
    <touch name="touch_br_r0" site="foot_br_r0"/>
    <touch name="touch_fl_r1" site="foot_fl_r1"/>
    <touch name="touch_fr_r1" site="foot_fr_r1"/>
    <touch name="touch_bl_r1" site="foot_bl_r1"/>
    <touch name="touch_br_r1" site="foot_br_r1"/>
  </sensor>
</mujoco>
